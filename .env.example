# Step 1:
# Run setup in the project root.
# If .env does not exist yet, setup will create it from this file.
#
#   ./setup
#
# Step 2:
# Open .env and paste your key after OPENAI_API_KEY=
#
#   OPENAI_API_KEY=sk-xxxx
#
# Step 3:
# Run:
#
#   sayit "你这个怎么还没弄完"

# Easiest option for most users:
OPENAI_API_KEY=

# Optional:
# If you use another OpenAI-compatible provider, uncomment and fill these.
# SAYIT_PROVIDER_DEFAULT=custom
# SAYIT_CUSTOM_BASE_URL=
# SAYIT_CUSTOM_MODEL=
# SAYIT_CUSTOM_API_KEY=

# Optional:
OPENROUTER_API_KEY=
